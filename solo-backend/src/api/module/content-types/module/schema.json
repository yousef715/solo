{
  "kind": "collectionType",
  "collectionName": "modules",
  "info": {
    "singularName": "module",
    "pluralName": "modules",
    "displayName": "Module",
    "description": "Learning blocks for courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "content_type": {
      "type": "enumeration",
      "enum": ["video", "text", "quiz", "interactive"],
      "required": true
    },
    "video_url": {
      "type": "string"
    },
    "content": {
      "type": "richtext"
    },
    "quiz_data": {
      "type": "json"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "modules"
    }
  }
}
